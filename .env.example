# Database
DATABASE_URL="postgresql://username:password@hostname:5432/tdc_matchmaker?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key"

# Email Configuration - Gmail SMTP (FREE!)
# Get App Password from: https://myaccount.google.com/apppasswords
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# Magic Link Secret (generate with: openssl rand -hex 32)
MAGIC_LINK_SECRET="your-magic-link-secret-key"

# AWS Configuration
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_S3_BUCKET="tdc-matchmaker-photos"
AWS_REGION="ap-south-1"

# Redis
REDIS_URL="redis://default:password@hostname:6379"
